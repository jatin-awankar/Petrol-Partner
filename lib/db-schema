-- =========================================
-- Petrol Partner - Full DB Schema (from scratch)
-- Compatible with Clerk auth (auth.uid() -> Clerk user id string)
-- =========================================

/* ===============================
   1. EXTENSIONS
   =============================== */
CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS "pgcrypto";

/* ===============================
   2. ENUM TYPES
   =============================== */
DO $$
BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_type WHERE typname = 'booking_status') THEN
    CREATE TYPE public.booking_status AS ENUM ('pending', 'confirmed', 'cancelled');
  END IF;

  IF NOT EXISTS (SELECT 1 FROM pg_type WHERE typname = 'ride_status') THEN
    CREATE TYPE public.ride_status AS ENUM ('scheduled', 'ongoing', 'completed', 'cancelled');
  END IF;

  IF NOT EXISTS (SELECT 1 FROM pg_type WHERE typname = 'payment_status') THEN
    CREATE TYPE public.payment_status AS ENUM ('pending', 'completed', 'failed');
  END IF;
END
$$ LANGUAGE plpgsql;

/* ===============================
   3. USER PROFILES (Clerk mapping)
   - internal UUID `id` used across DB as FK
   - clerk_id TEXT stores Clerk user id (auth.uid())
   =============================== */
CREATE TABLE IF NOT EXISTS public.user_profiles (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    clerk_id TEXT UNIQUE, -- Clerk user id string like "user_xxx..."
    full_name TEXT NOT NULL,
    email TEXT UNIQUE NOT NULL,
    college TEXT,
    is_verified BOOLEAN DEFAULT FALSE,
    avg_rating NUMERIC(3,2) DEFAULT 0,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   4. VEHICLES
   =============================== */
CREATE TABLE IF NOT EXISTS public.vehicles (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    owner_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    make TEXT NOT NULL,
    model TEXT NOT NULL,
    year INT,
    color TEXT,
    license_plate TEXT,
    vehicle_type TEXT,
    seats INT,
    is_verified BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   5. RIDE OFFERS
   =============================== */
CREATE TABLE IF NOT EXISTS public.ride_offers (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    driver_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    vehicle_id UUID REFERENCES public.vehicles(id) ON DELETE SET NULL,
    origin_lat DECIMAL,
    origin_lng DECIMAL,
    origin_address TEXT,
    destination_lat DECIMAL,
    destination_lng DECIMAL,
    destination_address TEXT,
    departure_time TIMESTAMP WITH TIME ZONE,
    available_seats INT,
    price_per_seat DECIMAL,
    total_distance_km DECIMAL,
    estimated_duration_minutes INT,
    ride_status public.ride_status DEFAULT 'scheduled',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   6. RIDE REQUESTS
   =============================== */
CREATE TABLE IF NOT EXISTS public.ride_requests (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    passenger_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    origin_lat DECIMAL,
    origin_lng DECIMAL,
    origin_address TEXT,
    destination_lat DECIMAL,
    destination_lng DECIMAL,
    destination_address TEXT,
    departure_time TIMESTAMP WITH TIME ZONE,
    seats_needed INT,
    price_offer DECIMAL,
    total_distance_km DECIMAL,
    estimated_duration_minutes INT,
    ride_status public.ride_status DEFAULT 'scheduled',
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   7. BOOKINGS
   =============================== */
CREATE TABLE IF NOT EXISTS public.bookings (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    rider_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    ride_offer_id UUID REFERENCES public.ride_offers(id) ON DELETE CASCADE,
    ride_request_id UUID REFERENCES public.ride_requests(id) ON DELETE CASCADE,
    seats_booked INT,
    total_price DECIMAL,
    booking_status public.booking_status DEFAULT 'pending',
    can_review BOOLEAN DEFAULT FALSE,
    pickup_address TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   8. PAYMENT METHODS
   =============================== */
CREATE TABLE IF NOT EXISTS public.payment_methods (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    method_type TEXT,
    display_name TEXT,
    is_default BOOLEAN DEFAULT FALSE,
    card_last_four TEXT,
    card_brand TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now(),
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   9. TRANSACTIONS
   =============================== */
CREATE TABLE IF NOT EXISTS public.transactions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    booking_id UUID REFERENCES public.bookings(id) ON DELETE CASCADE,
    payer_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    payee_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    payment_method_id UUID REFERENCES public.payment_methods(id) ON DELETE SET NULL,
    amount DECIMAL,
    platform_fee DECIMAL,
    driver_earnings DECIMAL,
    payment_status public.payment_status DEFAULT 'pending',
    transaction_reference TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   10. RIDE REVIEWS
   =============================== */
CREATE TABLE IF NOT EXISTS public.ride_reviews (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    booking_id UUID REFERENCES public.bookings(id) ON DELETE CASCADE,
    reviewer_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    reviewee_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    rating INT CHECK (rating BETWEEN 1 AND 5),
    review_text TEXT,
    is_driver_review BOOLEAN,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   11. EMERGENCY CONTACTS
   =============================== */
CREATE TABLE IF NOT EXISTS public.emergency_contacts (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id UUID REFERENCES public.user_profiles(id) ON DELETE CASCADE,
    name TEXT,
    phone TEXT,
    relationship TEXT,
    is_primary BOOLEAN DEFAULT FALSE,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   12. CONVERSATIONS & MESSAGES
   =============================== */
CREATE TABLE IF NOT EXISTS public.conversations (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    ride_offer_id UUID REFERENCES public.ride_offers(id),
    ride_request_id UUID REFERENCES public.ride_requests(id),
    participant_1 UUID REFERENCES public.user_profiles(id),
    participant_2 UUID REFERENCES public.user_profiles(id),
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

CREATE TABLE IF NOT EXISTS public.messages (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    conversation_id UUID REFERENCES public.conversations(id) ON DELETE CASCADE,
    sender_id UUID REFERENCES public.user_profiles(id),
    content TEXT,
    created_at TIMESTAMP WITH TIME ZONE DEFAULT now()
);

/* ===============================
   13. INDEXES
   =============================== */
CREATE INDEX IF NOT EXISTS idx_user_profiles_email ON public.user_profiles(email);
CREATE INDEX IF NOT EXISTS idx_vehicles_owner_id ON public.vehicles(owner_id);
CREATE INDEX IF NOT EXISTS idx_ride_offers_driver_id ON public.ride_offers(driver_id);
CREATE INDEX IF NOT EXISTS idx_ride_requests_passenger_id ON public.ride_requests(passenger_id);
CREATE INDEX IF NOT EXISTS idx_bookings_ride_offer_id ON public.bookings(ride_offer_id);
CREATE INDEX IF NOT EXISTS idx_bookings_ride_request_id ON public.bookings(ride_request_id);
CREATE INDEX IF NOT EXISTS idx_bookings_rider_id ON public.bookings(rider_id);
CREATE INDEX IF NOT EXISTS idx_transactions_booking_id ON public.transactions(booking_id);
CREATE INDEX IF NOT EXISTS idx_transactions_status ON public.transactions(payment_status);
CREATE INDEX IF NOT EXISTS idx_ride_reviews_booking_id ON public.ride_reviews(booking_id);
CREATE INDEX IF NOT EXISTS idx_emergency_contacts_user_id ON public.emergency_contacts(user_id);
CREATE INDEX IF NOT EXISTS idx_conversations_participants ON public.conversations(participant_1, participant_2);
CREATE INDEX IF NOT EXISTS idx_messages_conversation_id ON public.messages(conversation_id);

