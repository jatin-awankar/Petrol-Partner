-- update seats after booking
CREATE OR REPLACE FUNCTION public.update_seats_after_booking()
RETURNS TRIGGER
LANGUAGE plpgsql
SECURITY DEFINER
AS $func$
BEGIN
    IF NEW.ride_offer_id IS NOT NULL THEN
        UPDATE public.ride_offers
        SET available_seats = GREATEST(COALESCE(available_seats,0) - COALESCE(NEW.seats_booked,0), 0),
            updated_at = now()
        WHERE id = NEW.ride_offer_id;
    END IF;

    IF NEW.ride_request_id IS NOT NULL THEN
        UPDATE public.ride_requests
        SET seats_needed = GREATEST(COALESCE(seats_needed,0) - COALESCE(NEW.seats_booked,0), 0),
            updated_at = now()
        WHERE id = NEW.ride_request_id;
    END IF;

    RETURN NEW;
END;
$func$;

-- enable reviews after ride completion (we'll trigger via ride status update triggers)
CREATE OR REPLACE FUNCTION public.enable_reviews_after_completion()
RETURNS TRIGGER
LANGUAGE plpgsql
SECURITY DEFINER
AS $func$
BEGIN
    -- When a ride_offer is marked completed, enable review on bookings connected to it
    IF TG_TABLE_NAME = 'ride_offers' THEN
      UPDATE public.bookings
      SET can_review = TRUE, updated_at = now()
      WHERE ride_offer_id = NEW.id;
    ELSIF TG_TABLE_NAME = 'ride_requests' THEN
      UPDATE public.bookings
      SET can_review = TRUE, updated_at = now()
      WHERE ride_request_id = NEW.id;
    END IF;

    RETURN NEW;
END;
$func$;

-- driver earnings calculation helper
CREATE OR REPLACE FUNCTION public.calculate_driver_earnings(amount DECIMAL)
RETURNS DECIMAL
LANGUAGE sql
STABLE
SECURITY DEFINER
AS $func$
    SELECT amount * 0.85;
$func$;

/* ===============================
   15. TRIGGERS
   =============================== */
-- Booking seats update
DROP TRIGGER IF EXISTS trg_update_seats_after_booking ON public.bookings;
CREATE TRIGGER trg_update_seats_after_booking
AFTER INSERT ON public.bookings
FOR EACH ROW EXECUTE FUNCTION public.update_seats_after_booking();

-- Enable reviews when ride status becomes 'completed'
DROP TRIGGER IF EXISTS trg_enable_reviews_ride_offer ON public.ride_offers;
CREATE TRIGGER trg_enable_reviews_ride_offer
AFTER UPDATE OF ride_status ON public.ride_offers
FOR EACH ROW
WHEN (NEW.ride_status = 'completed')
EXECUTE FUNCTION public.enable_reviews_after_completion();

DROP TRIGGER IF EXISTS trg_enable_reviews_ride_request ON public.ride_requests;
CREATE TRIGGER trg_enable_reviews_ride_request
AFTER UPDATE OF ride_status ON public.ride_requests
FOR EACH ROW
WHEN (NEW.ride_status = 'completed')
EXECUTE FUNCTION public.enable_reviews_after_completion();

