/* ===============================
   17. RLS POLICIES (using clerk_id -> auth.uid() mapping)
   - Policies compare auth.uid() (Clerk ID string) with user_profiles.clerk_id
   - For FK columns that are UUIDs (owner_id, rider_id...), we check that the corresponding user_profiles row
     has clerk_id = auth.uid() via EXISTS(...) or via SELECT.
   =============================== */

-- ---- user_profiles: user manages own profile via clerk_id match
DROP POLICY IF EXISTS "users_manage_own_profiles" ON public.user_profiles;
CREATE POLICY "users_manage_own_profiles"
ON public.user_profiles
FOR ALL
TO authenticated
USING (clerk_id = auth.uid())
WITH CHECK (clerk_id = auth.uid());

-- ---- vehicles: owner can manage own vehicles
DROP POLICY IF EXISTS "users_manage_own_vehicles" ON public.vehicles;
CREATE POLICY "users_manage_own_vehicles"
ON public.vehicles
FOR ALL
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = owner_id AND up.clerk_id = auth.uid()
  )
)
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = owner_id AND up.clerk_id = auth.uid()
  )
);

-- ---- ride_offers: drivers can manage their own offers
DROP POLICY IF EXISTS "users_manage_own_ride_offers" ON public.ride_offers;
CREATE POLICY "users_manage_own_ride_offers"
ON public.ride_offers
FOR ALL
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = driver_id AND up.clerk_id = auth.uid()
  )
)
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = driver_id AND up.clerk_id = auth.uid()
  )
);

-- ---- ride_requests: passengers can manage their own requests
DROP POLICY IF EXISTS "users_manage_own_ride_requests" ON public.ride_requests;
CREATE POLICY "users_manage_own_ride_requests"
ON public.ride_requests
FOR ALL
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = passenger_id AND up.clerk_id = auth.uid()
  )
)
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = passenger_id AND up.clerk_id = auth.uid()
  )
);

-- ---- bookings: rider can manage their own bookings (rider_id)
DROP POLICY IF EXISTS "users_manage_own_bookings" ON public.bookings;
CREATE POLICY "users_manage_own_bookings"
ON public.bookings
FOR ALL
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = rider_id AND up.clerk_id = auth.uid()
  )
)
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = rider_id AND up.clerk_id = auth.uid()
  )
);

-- ---- transactions: allow reading if payer or payee matches current user
DROP POLICY IF EXISTS "users_manage_own_transactions" ON public.transactions;
CREATE POLICY "users_manage_own_transactions"
ON public.transactions
FOR SELECT
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE (up.id = payer_id OR up.id = payee_id) AND up.clerk_id = auth.uid()
  )
);

-- ---- emergency contacts
DROP POLICY IF EXISTS "users_manage_own_emergency_contacts" ON public.emergency_contacts;
CREATE POLICY "users_manage_own_emergency_contacts"
ON public.emergency_contacts
FOR ALL
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = user_id AND up.clerk_id = auth.uid()
  )
)
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = user_id AND up.clerk_id = auth.uid()
  )
);

-- ---- conversations: allow participants access
DROP POLICY IF EXISTS "users_access_own_conversations" ON public.conversations;
CREATE POLICY "users_access_own_conversations"
ON public.conversations
FOR ALL
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE (up.id = participant_1 OR up.id = participant_2) AND up.clerk_id = auth.uid()
  )
)
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE (up.id = participant_1 OR up.id = participant_2) AND up.clerk_id = auth.uid()
  )
);

-- ---- messages: ensure sender is current user and conversation is accessible
DROP POLICY IF EXISTS "users_access_conversation_messages" ON public.messages;
CREATE POLICY "users_access_conversation_messages"
ON public.messages
FOR ALL
TO authenticated
USING (
  EXISTS (
    SELECT 1 FROM public.conversations c
    JOIN public.user_profiles up ON ( (c.participant_1 = up.id OR c.participant_2 = up.id) AND up.clerk_id = auth.uid() )
    WHERE c.id = conversation_id
  )
)
WITH CHECK (
  EXISTS (
    SELECT 1 FROM public.user_profiles up
    WHERE up.id = sender_id AND up.clerk_id = auth.uid()
  )
);

/* ===============================
   18. UTILITY: CLEANUP / ADMIN FUNCTIONS (optional)
   - kept but do NOT trigger on auth.users; Clerk doesn't insert into auth.users
   =============================== */

CREATE OR REPLACE FUNCTION public.cleanup_demo_data()
RETURNS VOID
LANGUAGE plpgsql
SECURITY DEFINER
AS $cleanup$
DECLARE
    demo_user_ids UUID[];
BEGIN
    SELECT ARRAY_AGG(id) INTO demo_user_ids
    FROM public.user_profiles
    WHERE email LIKE '%@rideshare.com';

    IF demo_user_ids IS NOT NULL THEN
      DELETE FROM public.messages WHERE sender_id = ANY(demo_user_ids);
      DELETE FROM public.conversations WHERE participant_1 = ANY(demo_user_ids) OR participant_2 = ANY(demo_user_ids);
      DELETE FROM public.ride_reviews WHERE reviewer_id = ANY(demo_user_ids) OR reviewee_id = ANY(demo_user_ids);
      DELETE FROM public.transactions WHERE payer_id = ANY(demo_user_ids) OR payee_id = ANY(demo_user_ids);
      DELETE FROM public.bookings WHERE rider_id = ANY(demo_user_ids);
      DELETE FROM public.ride_offers WHERE driver_id = ANY(demo_user_ids);
      DELETE FROM public.ride_requests WHERE passenger_id = ANY(demo_user_ids);
      DELETE FROM public.vehicles WHERE owner_id = ANY(demo_user_ids);
      DELETE FROM public.payment_methods WHERE user_id = ANY(demo_user_ids);
      DELETE FROM public.emergency_contacts WHERE user_id = ANY(demo_user_ids);
      DELETE FROM public.user_profiles WHERE id = ANY(demo_user_ids);
    END IF;
END;
$cleanup$;

