-- migrations/001_create_auth_tables.sql

CREATE EXTENSION IF NOT EXISTS "uuid-ossp";
CREATE EXTENSION IF NOT EXISTS "pgcrypto";

-- USERS table
CREATE TABLE IF NOT EXISTS users (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  email TEXT NOT NULL UNIQUE,
  password_hash TEXT,                -- nullable for future OAuth
  full_name TEXT,
  phone TEXT,
  profile_image TEXT,
  is_verified BOOLEAN DEFAULT false,
  role TEXT DEFAULT 'user',          -- can be 'user', 'driver', 'admin'
  created_at TIMESTAMPTZ DEFAULT now(),
  updated_at TIMESTAMPTZ DEFAULT now()
);

-- REFRESH TOKENS table
CREATE TABLE IF NOT EXISTS refresh_tokens (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  user_id uuid NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  token_hash TEXT NOT NULL,
  user_agent TEXT,
  ip TEXT,
  expires_at TIMESTAMPTZ NOT NULL,
  created_at TIMESTAMPTZ DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_refresh_user ON refresh_tokens(user_id);
CREATE INDEX IF NOT EXISTS idx_refresh_hash ON refresh_tokens(token_hash);

 -- Ride Offers table
CREATE TABLE IF NOT EXISTS ride_offers (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  driver_id uuid NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  pickup_location text NOT NULL,
  drop_location text NOT NULL,
  pickup_lat double precision NOT NULL,
  pickup_lng double precision NOT NULL,
  drop_lat double precision NOT NULL,
  drop_lng double precision NOT NULL,
  available_seats integer NOT NULL CHECK (available_seats >= 0),
  price_per_seat numeric(10,2) NOT NULL,
  date date NOT NULL,
  time time NOT NULL,
  vehicle_details text,
  notes text,
  status text DEFAULT 'active' CHECK (status IN ('active','completed','cancelled')),
  created_at timestamptz DEFAULT now(),
  updated_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_ride_driver ON ride_offers(driver_id);
CREATE INDEX IF NOT EXISTS idx_ride_status ON ride_offers(status);

-- Ride Requests table
CREATE TABLE IF NOT EXISTS ride_requests (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  passenger_id uuid NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  pickup_location text NOT NULL,
  drop_location text NOT NULL,
  pickup_lat double precision NOT NULL,
  pickup_lng double precision NOT NULL,
  drop_lat double precision NOT NULL,
  drop_lng double precision NOT NULL,
  seats_required integer NOT NULL CHECK (seats_required >= 0),
  date date NOT NULL,
  time time NOT NULL,
  status text DEFAULT 'active' CHECK (status IN ('active','matched','cancelled','completed')),
  notes text,
  created_at timestamptz DEFAULT now(),
  updated_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_request_passenger ON ride_requests(passenger_id);
CREATE INDEX IF NOT EXISTS idx_request_status ON ride_requests(status);


 -- Bookings table
CREATE TABLE bookings (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  driver_id uuid REFERENCES users(id) ON DELETE CASCADE,
  passenger_id uuid REFERENCES users(id) ON DELETE CASCADE,
  ride_offer_id uuid REFERENCES ride_offers(id) ON DELETE SET NULL,
  ride_request_id uuid REFERENCES ride_requests(id) ON DELETE SET NULL,
  seats_booked integer DEFAULT 1 CHECK (seats_booked > 0),
  total_price numeric(10,2) NOT NULL CHECK (total_price >= 0),
  status text DEFAULT 'pending' CHECK (status IN ('pending', 'confirmed', 'cancelled', 'completed')),
  role text CHECK (role IN ('driver', 'passenger')),
  created_at timestamptz DEFAULT now(),
  updated_at timestamptz DEFAULT now()
);


CREATE INDEX IF NOT EXISTS idx_booking_driver ON bookings(driver_id);
CREATE INDEX IF NOT EXISTS idx_booking_passenger ON bookings(passenger_id);
CREATE INDEX IF NOT EXISTS idx_booking_status ON bookings(status);


-- chat_rooms table
CREATE TABLE IF NOT EXISTS chat_rooms (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  booking_id uuid UNIQUE NOT NULL REFERENCES bookings(id) ON DELETE CASCADE,
  driver_id uuid NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  passenger_id uuid NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  is_archived boolean DEFAULT false,
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_chatrooms_booking ON chat_rooms(booking_id);
CREATE INDEX IF NOT EXISTS idx_chatrooms_driver ON chat_rooms(driver_id);
CREATE INDEX IF NOT EXISTS idx_chatrooms_passenger ON chat_rooms(passenger_id);

-- messages table
CREATE TABLE IF NOT EXISTS messages (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  chat_room_id uuid NOT NULL REFERENCES chat_rooms(id) ON DELETE CASCADE,
  sender_id uuid NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  receiver_id uuid NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  content text NOT NULL,
  is_read boolean DEFAULT false,
  metadata jsonb DEFAULT '{}'::jsonb,
  created_at timestamptz DEFAULT now()
);

CREATE INDEX IF NOT EXISTS idx_messages_chatroom ON messages(chat_room_id);
CREATE INDEX IF NOT EXISTS idx_messages_sender ON messages(sender_id);
CREATE INDEX IF NOT EXISTS idx_messages_receiver ON messages(receiver_id);
CREATE INDEX IF NOT EXISTS idx_messages_created_at ON messages(created_at DESC);


-- table for updates
CREATE TABLE IF NOT EXISTS community_updates (
  id uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  type text CHECK (type IN ('announcement', 'event', 'update', 'alert', 'maintenance')),
  title text NOT NULL,
  content text NOT NULL,
  created_at TIMESTAMPTZ DEFAULT NOW(),
  author TEXT DEFAULT 'Petrol Partner Team',
  image_url TEXT
)